# Shopify app config for DTF Now Reprint Tracker.
# client_id matches the app you created in the Shopify dev dashboard.
# After deploying to Vercel, set application_url + redirect URLs to your
# Vercel URL (or run `shopify app config link` to sync automatically).

client_id = "9c2a00b60370faa5a0c2ba214180bf03"
name = "dtfnow-reprint-tracker"
handle = "dtfnow-reprint-tracker"
application_url = "https://REPLACE-WITH-YOUR-APP.vercel.app"
embedded = true

[access_scopes]
# read_orders lets the app look up order value/customer for context.
scopes = "read_orders"

[auth]
redirect_urls = [
  "https://REPLACE-WITH-YOUR-APP.vercel.app/auth/callback",
  "https://REPLACE-WITH-YOUR-APP.vercel.app/auth/shopify/callback",
  "https://REPLACE-WITH-YOUR-APP.vercel.app/api/auth/callback"
]

[webhooks]
api_version = "2025-01"

  [[webhooks.subscriptions]]
  uri = "/webhooks/app/uninstalled"
  topics = ["app/uninstalled"]

  [[webhooks.subscriptions]]
  topics = [ "app/scopes_update" ]
  uri = "/webhooks/app/scopes_update"
