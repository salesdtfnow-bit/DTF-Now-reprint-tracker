# ---- Shopify (from your Partner app: Apps > your app > Configuration) ----
SHOPIFY_API_KEY=your_client_id
SHOPIFY_API_SECRET=your_client_secret
SHOPIFY_APP_URL=https://your-app.vercel.app
SCOPES=read_orders

# App handle, used to build the "Open in Reprint Tracker" deep link in Slack.
# This is the `handle` from shopify.app.toml.
SHOPIFY_APP_HANDLE=dtfnow-reprint-tracker

# ---- Database ----
# Local dev (SQLite): DATABASE_URL="file:dev.sqlite"
# Production on Vercel: use Postgres (Vercel Postgres / Neon). Example:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL="file:dev.sqlite"

# ---- Slack ----
# Bot token (xoxb-...) from your Slack app with chat:write scope.
# Invite the bot to #reprint-request. Channel ID is set in app Settings.
SLACK_BOT_TOKEN=xoxb-your-bot-token
