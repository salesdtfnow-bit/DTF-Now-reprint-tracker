// Prisma schema for the DTF Now Reprint Tracker.
// Session model is required by @shopify/shopify-app-session-storage-prisma.
// Provider is postgresql for production (Vercel + Neon/Vercel Postgres).
// For LOCAL dev with SQLite, set provider = "sqlite" and DATABASE_URL="file:dev.sqlite".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")     // prisma+postgres:// (Accelerate) - runtime
  directUrl = env("POSTGRES_URL")     // direct postgres:// - used by `prisma db push`
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ReprintRequest {
  id          String    @id @default(cuid())
  shop        String

  orderName   String?
  orderGid    String?

  reason      String
  notes       String?
  status      String    @default("pending") // pending | done | written_off
  raisedBy    String?

  lengthM         Float?
  minutes         Float?
  reposted        Boolean?
  completedBy     String?
  completedAt     DateTime?

  shippingService String?   // name of the DPD/RM service used to reship
  shippingCost    Float?    // real carrier cost of the reship

  // Customer-facing tracking
  publicToken     String?   @unique // random token for the customer tracking link
  progress        String    @default("received") // received | reprinting | packed | dispatched
  trackingNumber  String?
  trackingCarrier String?   // dpd | royal_mail | other (for the track link)
  customerEmail   String?   // captured from the order at raise time (for the email)

  slackTs     String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shop, status])
  @@index([shop, createdAt])
}

model Settings {
  shop           String   @id
  filmPerM       Float    @default(2.5)
  labourPerH     Float    @default(14.15)
  machinePerH    Float    @default(8.0)
  slackChannelId String   @default("C0B7S8W09R6")

  // Auto time-estimate model (minutes): processing + rip/m + print(length/speed) + pack
  processingMin  Float    @default(1.5)
  ripMinPerM     Float    @default(2.5)
  printSpeedMph  Float    @default(23)
  packMin        Float    @default(3)

  seeded         Boolean  @default(false) // employees + shipping rates seeded
  updatedAt      DateTime @updatedAt
}

model Employee {
  id        String   @id @default(cuid())
  shop      String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([shop, active])
}

model ShippingRate {
  id        String   @id @default(cuid())
  shop      String
  name      String
  cost      Float    @default(0)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([shop, active])
}
