// Prisma schema for the DTF Now Reprint Tracker.
// Session model is required by @shopify/shopify-app-session-storage-prisma.
// Provider is postgresql for production (Vercel + Neon/Vercel Postgres).
// For LOCAL dev with SQLite, set provider = "sqlite" and DATABASE_URL="file:dev.sqlite".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")     // prisma+postgres:// (Accelerate) - runtime
  directUrl = env("POSTGRES_URL")     // direct postgres:// - used by `prisma db push`
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ReprintRequest {
  id          String    @id @default(cuid())
  shop        String

  orderName   String?
  orderGid    String?

  reason      String
  notes       String?
  status      String    @default("pending") // pending | done | written_off
  raisedBy    String?

  lengthM     Float?
  minutes     Float?
  reposted    Boolean?
  completedBy String?
  completedAt DateTime?

  slackTs     String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shop, status])
  @@index([shop, createdAt])
}

model Settings {
  shop           String   @id
  filmPerM       Float    @default(2.5)
  labourPerH     Float    @default(14.15)
  machinePerH    Float    @default(8.0)
  slackChannelId String   @default("C0B7S8W09R6")
  updatedAt      DateTime @updatedAt
}
